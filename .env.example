# Copy to .env.local for local development:
#   cp .env.example .env.local

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql://flight_seek:flight_seek@localhost:5432/flight_seek

# Redis
REDIS_URL=redis://localhost:6379

# NOAA / NWS weather.gov API (required User-Agent header; include contact email)
NOAA_USER_AGENT=(flight_seek, you@example.com)

# EUROCONTROL (public) feed URL (optional; depends on your approved access)
# Set this to the public endpoint/feed you are permitted to consume.
EUROCONTROL_PUBLIC_FEED_URL=

# Commercial global aviation API (example defaults to FlightQueue)
COMM_AVIATION_API_BASE_URL=https://api.flightqueue.com/v1
COMM_AVIATION_API_KEY=

# Public site URL (optional; used for absolute links and metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
